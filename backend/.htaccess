# ============================================================
# Bilge Yolcu Kontrol Paneli — Apache .htaccess (VDS/WHM)
# Dosya: /home/bilgeyolcu/public_html/yonetim/.htaccess
# ============================================================
#
# Mimari:
#   Apache (443/SSL)
#     ├── /yonetim/api/*      → mod_proxy → Gunicorn (127.0.0.1:5000)
#     ├── /yonetim/assets/*   → statik dosya (Vue.js build)
#     └── /yonetim/*          → SPA fallback (index.html)
#
# WHM Gereksinimi:
#   WHM → Apache Configuration → Global → mod_proxy: ON
#   WHM → Apache Configuration → Global → mod_proxy_http: ON
# ============================================================

Options -Indexes
Options +FollowSymLinks

RewriteEngine On

# ── 1. API İsteklerini Gunicorn'a Proxy'le ────────────────
# /yonetim/api/* → http://127.0.0.1:5000/api/*
# Passenger yerine Gunicorn kullanıyoruz (daha performanslı)
RewriteCond %{REQUEST_URI} ^/yonetim/api/
RewriteRule ^api/(.*)$ http://127.0.0.1:5000/api/$1 [P,L,QSA]

# mod_proxy header'ları
<IfModule mod_proxy.c>
    ProxyPreserveHost On
    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Real-IP %{REMOTE_ADDR}e
    RequestHeader set X-Forwarded-For %{REMOTE_ADDR}e
</IfModule>

# ── 2. Vue.js SPA History Mode ────────────────────────────
# Gerçek dosya yoksa index.html'e yönlendir
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/yonetim/api/
RewriteRule ^(.*)$ /yonetim/index.html [L]

# ── 3. Güvenlik Header'ları ───────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://bilgeyolcu.com"
</IfModule>

# ── 4. Hassas Dosyaları Koru ──────────────────────────────
<FilesMatch "\.(env|pyc|pyo|db|sqlite3|log|pid)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteRule ^\.git - [F,L]
    RewriteRule ^\.env - [F,L]
</IfModule>

# ── 5. Statik Dosya Önbelleği ─────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Vite hash'li dosyalar — 1 yıl cache
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    # Resimler
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    # HTML — her zaman taze
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── 6. Gzip Sıkıştırma ───────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE font/woff font/woff2
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
