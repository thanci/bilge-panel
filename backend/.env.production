# ============================================================
# Bilge Yolcu Kontrol Paneli — ÜRETIM Ortam Değişkenleri
# Dosya konumu: /home/bilgeyolcu/bilge-panel/backend/.env
# ============================================================

# --- Uygulama Genel ---
FLASK_ENV=production
FLASK_PORT=5000

# ÖNEMLİ: Güçlü anahtar üretin:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_GUCLU_ANAHTAR_URETIP_YAPIŞTIRIN

# --- JWT Ayarları ---
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
JWT_SECRET_KEY=BURAYA_AYRI_GUCLU_ANAHTAR_URETIP_YAPIŞTIRIN

# --- Veritabanı ---
# Otomatik göreli yol kullanılır (config.py içinde)
# Manuel override:
# DATABASE_URL=sqlite:////home/bilgeyolcu/bilge-panel/backend/bilgeyolcu.db

# --- Redis ---
# VDS'de Redis aktif — rate limiting + Celery broker
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# --- LLM API Anahtarları ---
# ÖNCEKİ ANAHTARLARI REVOKE EDİP YENİ OLUŞTURUN!
GEMINI_API_KEY=YENI_ANAHTAR_BURAYA
ANTHROPIC_API_KEY=YENI_ANAHTAR_BURAYA
OPENAI_API_KEY=YENI_ANAHTAR_BURAYA

# --- LLM Model Seçimi ---
PRIMARY_MODEL=gemini-2.5-flash
FALLBACK_MODEL_1=claude-haiku-3-5
FALLBACK_MODEL_2=gpt-4o-mini

# --- Maliyet Kontrolü ---
DAILY_API_BUDGET=2.00
BUDGET_WARNING_THRESHOLD=0.80

# --- XenForo REST API ---
XENFORO_BASE_URL=https://bilgeyolcu.com
XENFORO_API_KEY=YENI_ANAHTAR_BURAYA
XENFORO_ADMIN_USER_ID=1
XENFORO_VERIFY_SSL=True
XENFORO_WEBROOT=/home/bilgeyolcu/public_html
XENFORO_DEFAULT_NODE_ID=5

# --- Dosya İzinleri ---
ALLOWED_EDIT_PATH=/home/bilgeyolcu/public_html

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YENI_TOKEN_BURAYA
TELEGRAM_CHAT_ID=6169677764

# --- Yedek ---
BACKUP_DIR=/home/bilgeyolcu/backups

# --- SSH (sunucu kendi kendine bağlanır) ---
SSH_HOST=127.0.0.1
SSH_PORT=22
SSH_USERNAME=bilgeyolcu
SSH_PASSWORD=
SSH_PHP_BIN=/usr/local/bin/ea-php83

# --- MySQL (Yedekleme için) ---
MYSQL_HOST=localhost
MYSQL_USER=bilgeyolcu_user
MYSQL_PASSWORD=SIFRE_BURAYA
MYSQL_DATABASE=bilgeyolcu_db
